package main;

pub fn main() -> void {
    for i in range(1, 21) {
        if i % 15 == 0 {
            log("FizzBuzz");
        } else {
            if i % 3 == 0 {
                log("Fizz");
            } else {
                if i % 5 == 0 {
                    log("Buzz");
                } else {
                    log(i);
                }
            }
        }
    }
    return;
}
