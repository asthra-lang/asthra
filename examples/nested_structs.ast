package main;

pub struct Inner {
    pub x: i32,
    pub y: i32
}

pub struct Outer {
    pub inner: Inner,
    pub name: string
}

pub fn main() -> void {
    let o: Outer = Outer { inner: Inner { x: 10, y: 20 }, name: "test" };
    log(o.inner.x);
    log(o.inner.y);
    log(o.name);

    return;
}
